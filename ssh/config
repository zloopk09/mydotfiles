# github
 Host github.com
     HostName github.com
     PreferredAuthentications publickey
     IdentityFile ~/.ssh/github_id_rsa
# bitbucket
 Host bitbucket.org
     HostName bitbucket.org
     PreferredAuthentications publickey
     IdentityFile ~/.ssh/bitbucket_id_rsa
     Port 22
     ProxyCommand nc -X 5 -x 127.0.0.1:1086 %h %p

